# Local / staging config for the money·data backend.
# Copy to `backend/.env` (gitignored) and edit. Loaded at startup by dotenvy.
# Real environment variables always take precedence over this file.

DATABASE_URL=postgres://postgres:pw@127.0.0.1:5432/postgres
JWT_SECRET=dev-local-insecure-secret

# Email + password login. On startup the app ensures this admin account exists
# with this password (created, or password reset to match). Set both to bootstrap
# your first login; change ADMIN_PASSWORD and restart to rotate it.
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=change-me-min-8

# Return the sign-in link in the HTTP response instead of emailing it.
# Lets you log in offline with no email provider. NEVER set this in production.
EXPOSE_MAGIC_LINK=true

# Leave unset for offline dev (no email sent; link comes back in the response).
# RESEND_API_KEY=
